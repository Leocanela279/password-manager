{
  "name": "cinnamon-key",
  "version": "1.0.0",
  "description": "Cinnamon Key Password Manager",
  "main": "main.js",
  "productName": "Cinnamon Key",
  "scripts": {
    "start": "env -u ELECTRON_RUN_AS_NODE electron .",
    "build:renderer": "pnpm --dir ../frontend build",
    "dist": "pnpm run build:renderer && electron-builder",
    "dist:mac": "pnpm run build:renderer && electron-builder --mac dmg",
    "dist:win": "pnpm run build:renderer && electron-builder --win nsis --x64"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.cinnamonkey.app",
    "productName": "Cinnamon Key",
    "afterPack": "scripts/afterPack.js",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "database.js",
      "package.json",
      "renderer/**/*",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/**/*.node"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Cinnamon Key"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "bcrypt",
      "sqlite3"
    ]
  }
}
